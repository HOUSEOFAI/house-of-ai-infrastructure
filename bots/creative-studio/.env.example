ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Drive folder name where generated assets get uploaded
# Requires rclone configured with a 'gdrive' remote
# Setup: https://rclone.org/drive/
GDRIVE_FOLDER=HouseOfAI/Creative Assets

# Optional: Your Pinterest board URL (default is Brooke's example board)
PINTEREST_BOARD_URL=https://pin.it/YOUR_BOARD_ID
